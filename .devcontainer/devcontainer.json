{
    "name": "Idris2 Devcontainer",

    "build": {
        "dockerfile": "Dockerfile"
    },
    "runArgs": [
        "--cap-add",
        "SYS_ADMIN",
        "--security-opt",
        "apparmor=unconfined",
        "--security-opt",
        "seccomp=unconfined"
    ],

    "remoteUser": "vscode",
    "containerUser": "vscode",
    "updateRemoteUserUID": false,
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/tmp/host-gitconfig,type=bind,readonly",
	"source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent.sock,type=bind"
    ],
    "remoteEnv": {
      "TERM": "${localEnv:TERM}",
      "SSH_AUTH_SOCK": "/ssh-agent.sock"
    },
    "postCreateCommand": "cp /tmp/host-gitconfig \"$HOME/.gitconfig\" && if [ -d \"$HOME/.config/.git\" ]; then git -C \"$HOME/.config\" pull --ff-only; else rm -rf \"$HOME/.config\" && git clone https://github.com/alebahn/.config.git \"$HOME/.config\"; fi && \"$HOME/.config/INSTALL\" --overwrite-bashrc",

    "customizations": {
        "vscode": {
            "extensions": [
                "bamboo.idris2-lsp"
            ]
        }
    }
}
